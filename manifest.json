*{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:linear-gradient(135deg,#fff7f7,#f6fff9);color:#351500}button,input,select{font:inherit}button{border:0;background:#a91e35;color:white;border-radius:14px;padding:12px 16px;font-weight:800;box-shadow:0 8px 20px #a91e3530}.loginPage{min-height:100vh;display:grid;place-items:center;padding:22px}.loginCard{width:min(430px,100%);background:#ffffffcc;border:1px solid #ead6d6;border-radius:26px;padding:28px;box-shadow:0 18px 55px #0002;text-align:center}.loginCard h1{color:#991b31;font-size:42px;margin:0 0 12px}.loginCard input{width:100%;padding:14px;margin:8px 0;border:1px solid #ead6d6;border-radius:14px}.check{display:flex;gap:9px;align-items:center;justify-content:center;margin:10px 0;color:#5c3c3c}.err{color:#991b31;display:block;margin-top:12px}.app{max-width:1180px;margin:auto;padding:22px}header{display:flex;justify-content:space-between;gap:18px;align-items:center}h1{font-size:44px;color:#a21b31;margin:.1em 0}.topBtns{display:flex;gap:10px;flex-wrap:wrap}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:20px 0}.stats div{background:#fff;border:1px solid #f0dede;border-radius:22px;padding:20px;box-shadow:0 10px 24px #0001}.stats span{display:block;color:#876}.stats b{font-size:34px}.entry{display:grid;grid-template-columns:1.2fr 1fr auto 1fr 1fr .7fr 1fr;gap:10px;background:#fff9;border:1px solid #f0dede;border-radius:24px;padding:16px}.entry input,.entry select,.search,.brow input{padding:13px;border:1px solid #ead6d6;border-radius:14px;background:white}.entry button:last-child{grid-column:1/-1}.small{padding:8px 12px}.upload{border:1px dashed #d8b5b5;border-radius:14px;padding:13px;text-align:center;background:white;color:#875;cursor:pointer}.msg{background:#fff0f2;color:#8b1025;padding:12px;border-radius:12px}nav{display:flex;gap:9px;margin:18px 0;overflow:auto}nav button{background:#fff;color:#9b1c31;border:1px solid #ead6d6;box-shadow:none;white-space:nowrap}nav button.active{background:#a91e35;color:#fff}.search{width:100%;margin-bottom:14px}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}.card{display:flex;gap:14px;background:#fff;border:1px solid #f0dede;border-radius:22px;padding:14px;box-shadow:0 10px 28px #0001}.thumb{width:82px;height:82px;border-radius:18px;background:#fff3f5;display:grid;place-items:center;font-size:34px;overflow:hidden;flex:0 0 auto}.thumb img{width:100%;height:100%;object-fit:cover}.card h3{margin:0}.danger{color:#b00020}.warn{color:#c96b00}.soon{color:#8a6b00}.ok{color:#087d36}.panel{background:#fff;border:1px solid #f0dede;border-radius:24px;padding:18px}.row,.brow{display:grid;grid-template-columns:1fr auto auto auto;gap:10px;align-items:center;border-bottom:1px solid #f3e4e4;padding:11px}.bakery{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:4px}.brow{grid-template-columns:1fr 110px;background:#fffaf8;border-radius:10px}small{color:#875}@media(max-width:760px){.app{padding:14px}header{display:block}h1{font-size:34px}.stats{grid-template-columns:repeat(2,1fr)}.entry{grid-template-columns:1fr}.row{grid-template-columns:1fr}.topBtns button{flex:1}.loginCard h1{font-size:34px}}
